#!/usr/bin/env sh
# Short launcher for the My Bookshelves CLI.

set -eu

SOURCE=$0
while [ -L "$SOURCE" ]; do
    SOURCE_DIR=$(CDPATH= cd -- "$(dirname -- "$SOURCE")" && pwd)
    LINK_TARGET=$(readlink "$SOURCE")
    case "$LINK_TARGET" in
        /*) SOURCE=$LINK_TARGET ;;
        *) SOURCE=$SOURCE_DIR/$LINK_TARGET ;;
    esac
done

ROOT_DIR=$(CDPATH= cd -- "$(dirname -- "$SOURCE")" && pwd)
UNAME=$(uname -s 2>/dev/null || printf unknown)

if [ -x "$ROOT_DIR/venv/bin/python" ]; then
    PYTHON_CMD="$ROOT_DIR/venv/bin/python"
elif [ -x "$ROOT_DIR/venv/Scripts/python.exe" ] && \
    { [ "${OS:-}" = "Windows_NT" ] || echo "$UNAME" | grep -Eq '^(MINGW|MSYS|CYGWIN)'; }; then
    PYTHON_CMD="$ROOT_DIR/venv/Scripts/python.exe"
elif [ -x "$ROOT_DIR/venv/Scripts/python" ] && \
    { [ "${OS:-}" = "Windows_NT" ] || echo "$UNAME" | grep -Eq '^(MINGW|MSYS|CYGWIN)'; }; then
    PYTHON_CMD="$ROOT_DIR/venv/Scripts/python"
elif command -v python3 >/dev/null 2>&1; then
    PYTHON_CMD="python3"
else
    PYTHON_CMD="python"
fi

cd "$ROOT_DIR"
exec "$PYTHON_CMD" "$ROOT_DIR/scripts/cli.py" "$@"
