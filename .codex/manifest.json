{
  "schema_version": 1,
  "name": "my-bookshelves-codex-adapter",
  "purpose": "Route Codex to the shared Antigravity/Codex agent instructions without duplicating source-of-truth behavior.",
  "generated_by": "scripts/sync_codex.py",
  "read_order": [
    ".codex/manifest.json",
    ".codex/rules.md",
    "AGENTS.md",
    ".agents/rules/my-bookshelves.md"
  ],
  "source_of_truth": {
    "project_rules": ".agents/rules/my-bookshelves.md",
    "shared_workflows": ".agents/workflows",
    "shared_skills": ".agents/skills",
    "codex_entrypoint": "AGENTS.md"
  },
  "workflows": {
    "auto-organize": {
      "triggers": [
        "/auto-organize",
        "auto-organize",
        "phan loai sach",
        "sap xep sach",
        "classify books",
        "organize Inbox"
      ],
      "codex_adapter": ".codex/workflows/auto-organize.md",
      "canonical_workflow": ".agents/workflows/auto-organize.md",
      "canonical_skill": ".agents/skills/auto-organize/SKILL.md",
      "classification_prompt": ".agents/skills/auto-organize/prompts/classify_book.md",
      "settings": ".agents/skills/auto-organize/config/settings.json"
    }
  },
  "tool_mapping": {
    "view_file": "Read the complete file with available Codex tooling or Get-Content -Raw.",
    "multi_replace_file_content": "Use apply_patch for batch edits, then validate the target file.",
    "turbo_comment": "Optimization note only.",
    "bash_commands": "Translate to PowerShell equivalents on Windows when needed."
  },
  "guardrails": [
    "Ask once before batch rename, move, upload, or commit/push.",
    "Run dry-run before destructive or upload operations.",
    "Never commit PDF, EPUB, DOCX, JPG, PNG, venv, node_modules, or IDE config.",
    "Preserve existing download_url and description fields in site/data.json.",
    "Use display names with spaces for category and topic in site/data.json.",
    "Validate JSON after editing JSON files.",
    "Log qualifying failures to ERRORS.md."
  ],
  "commands": {
    "sync_codex": "python scripts/cli.py codex-sync --base-dir .",
    "list": "python scripts/cli.py list --base-dir .",
    "rename_dry_run": "python scripts/cli.py rename --base-dir .",
    "rename_execute": "python scripts/cli.py rename --base-dir . --execute",
    "generate": "python scripts/cli.py generate --base-dir .",
    "structure": "python scripts/cli.py structure --base-dir .",
    "doctor": "python scripts/cli.py doctor --base-dir . --strict",
    "validate_json": "python scripts/cli.py validate --base-dir . --json",
    "unlock_pdfs": "python scripts/cli.py unlock-pdfs --base-dir .",
    "epub_to_pdf": "python scripts/cli.py epub-to-pdf --base-dir .",
    "upload_dry_run": "python scripts/cli.py upload --dry-run",
    "upload": "python scripts/cli.py upload"
  },
  "data_files": {
    "library_structure": "library_structure.log",
    "book_metadata": "site/data.json",
    "covers": "site/assets/covers",
    "inbox": "Inbox",
    "books": "Books"
  }
}
