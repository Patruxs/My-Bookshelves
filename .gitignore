# ╔═══════════════════════════════════════════════════════════╗
# ║  My Bookshelves — .gitignore (Storage Optimized)        ║
# ║  Books are stored via GitHub Releases, NOT in git tree  ║
# ╚═══════════════════════════════════════════════════════════╝

# ══════════════════════════════════════════════════
# 📚 BOOKS — DO NOT TRACK (use GitHub Releases)
# ══════════════════════════════════════════════════
*.pdf
*.epub
*.docx
*.mobi
*.azw3
*.djvu
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.tiff

# ══════════════════════════════════════════════════
# 🐍 Python
# ══════════════════════════════════════════════════
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
venv/
.venv/
*.egg-info/

# ══════════════════════════════════════════════════
# 📝 Logs & Temp
# ══════════════════════════════════════════════════
auto_organize.log
ERRORS.md
*.log
library_structure.log
!library_structure.log
_site/
.backups/
site/.backups/
*.tmp
*.bak

# ══════════════════════════════════════════════════
# 💻 OS Files
# ══════════════════════════════════════════════════
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ══════════════════════════════════════════════════
# 🛠️ IDE
# ══════════════════════════════════════════════════
.vscode/
.idea/
*.swp
*.swo
*~
node_modules/
.env
.env.*
