# ╔═══════════════════════════════════════════════════════════╗
# ║  My Bookshelves — .gitignore (Storage Optimized)        ║
# ║  Books are stored via GitHub Releases, NOT in git tree  ║
# ╚═══════════════════════════════════════════════════════════╝

# ══════════════════════════════════════════════════
# 📚 BOOKS — DO NOT TRACK (use GitHub Releases)
# ══════════════════════════════════════════════════
*.pdf
*.epub
*.mobi
*.azw3
*.djvu

# ══════════════════════════════════════════════════
# 🐍 Python
# ══════════════════════════════════════════════════
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
*.egg-info/

# ══════════════════════════════════════════════════
# 📝 Logs & Temp
# ══════════════════════════════════════════════════
auto_organize.log
*.log
!library_structure.log
repomix-output.xml
_site/

# ══════════════════════════════════════════════════
# 💻 OS Files
# ══════════════════════════════════════════════════
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ══════════════════════════════════════════════════
# 🛠️ IDE
# ══════════════════════════════════════════════════
.vscode/
.idea/
*.swp
*.swo
*~
